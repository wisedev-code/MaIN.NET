@page "/"
@rendermode @(new InteractiveServerRenderMode(prerender: true))
@inject IJSRuntime JS
@inject SettingsService SettingsStorage
@inject SettingsStateService SettingsState
@inject MaIN.Domain.Configuration.MaINSettings MaINSettings
@implements IDisposable
@using MaIN.Core.Hub
@using MaIN.Core.Hub.Contexts.Interfaces.ChatContext
@using MaIN.Domain.Configuration
@using MaIN.Domain.Entities
@using MaIN.Domain.Exceptions
@using MaIN.Domain.Models
@using MaIN.Domain.Models.Abstract
@using MaIN.Services
@using MaIN.Services.Constants
@using Markdig
@using Message = MaIN.Domain.Entities.Message
@using MessageType = MaIN.Domain.Entities.MessageType
<link rel="stylesheet" href="home.css">

<PageTitle>MaIN Infer</PageTitle>

<ErrorNotification @bind-ErrorMessage="_errorMessage" />

@if (_showSettings)
{
    <Settings ShowCloseButton="@_hasExistingConfig"
              OnSettingsApplied="@HandleSettingsApplied"
              OnClose="@HideSettings" />
}

<div class="chat-container" id="chat-container">
    @if (_isDragging)
    {
        <div class="drop-overlay">
            <div class="drop-overlay-content">
                <FluentIcon Value="@(new Icons.Regular.Size48.ArrowDownload())" Style="fill: var(--accent-base-color);" />
                <span>Drop files here</span>
            </div>
        </div>
    }

    <FluentProgress Visible="@(_isLoading)" Style="width: 100%; margin: 0; color: var(--accent-base-color)"/>

    <div class="messages-container" id="messages-container">
        @foreach (var conversation in Messages)
        {
            @if (conversation.Message.Role != "System")
            {
                <FluentCard class="@(conversation.Message.Role == "User" ? "message-card user-message" : "message-card bot-message")">
                    @if (conversation.Message.Role == "User")
                    {
                        @if (conversation.AttachedFiles.Any() || conversation.AttachedImages.Any())
                        {
                            <div class="attached-files-display">
                                @foreach (var image in conversation.AttachedImages)
                                {
                                    <div class="history-image-preview" title="@image.Name">
                                        <img src="data:image/png;base64,@image.Base64" alt="@image.Name" />
                                    </div>
                                }
                                @foreach (var fileName in conversation.AttachedFiles)
                                {
                                    <span class="attached-file-tag">
                                        <FluentIcon Value="@(new Icons.Regular.Size16.Document())"/>
                                        @fileName
                                    </span>
                                }
                            </div>
                        }
                        <div>
                            @((MarkupString)Markdown.ToHtml(conversation.Message.Content ?? string.Empty, _markdownPipeline))
                        </div>
                    }
                    else
                    {
                        @if (conversation.Message.Images?.Any() == true)
                        {
                            <div class="generated-images">
                                @foreach (var imageBytes in conversation.Message.Images)
                                {
                                    var b64 = Convert.ToBase64String(imageBytes);
                                    <div class="image-wrapper">
                                        <a href="data:image/png;base64,@b64" target="_blank">
                                            <img src="data:image/png;base64,@b64" class="generated-image" alt="generated image" />
                                        </a>
                                        <div class="image-actions">
                                            <a href="data:image/png;base64,@b64" download="generated-image.png"
                                               class="image-action-btn" title="Download">
                                                <FluentIcon Value="@(new Icons.Filled.Size24.ArrowDownload())"
                                                            Style="fill: var(--accent-base-color);" />
                                            </a>
                                            <span class="image-action-btn" title="Copy to clipboard"
                                                  @onclick="@(async () => await CopyImageToClipboard(b64))">
                                                <FluentIcon Value="@(new Icons.Filled.Size24.Copy())"
                                                            Style="fill: var(--accent-base-color);" />
                                            </span>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div>
                                @if (conversation.HasReasoning)
                                {
                                    <div class="reasoning-row">
                                        <span class="brain-toggle" title="@(conversation.ShowReason ? "Hide reasoning" : "Show reasoning")"
                                              @onclick="@(() => ToggleReasoning(conversation))">
                                            <FluentIcon Value="@(new Icons.Regular.Size24.Brain())"
                                                        Style="@($"fill: {(conversation.ShowReason ? "var(--accent-base-color)" : "var(--neutral-foreground-hint)")};")"/>
                                        </span>
                                        @if (conversation.ShowReason)
                                        {
                                            <div class="thinker reasoning-text"
                                                 style="border-radius: 10px; padding: 10px; border-width: 2px; background-color: var(--neutral-fill-hover)">
                                                @((MarkupString)Markdown.ToHtml(conversation.ComputedReasoning, _markdownPipeline))
                                            </div>
                                        }
                                    </div>
                                    <hr class="reasoning-hr"/>
                                }
                                @((MarkupString)Markdown.ToHtml(conversation.ComputedContent, _markdownPipeline))
                            </div>
                        }
                    }
                </FluentCard>
            }
        }
        @if (_isLoading)
        {
            @if (Utils.ImageGen)
            {
                <span class="message-role-bot" style="font-style: italic; font-size: small">This might take a while...</span>
            }
            else if (_incomingMessage != null || _incomingReasoning != null)
            {
                <FluentCard class="message-card bot-message">
                    @if (_isThinking)
                    {
                        <span class="thinker">
                            @((MarkupString)Markdown.ToHtml(_incomingReasoning ?? string.Empty, _markdownPipeline))
                        </span>
                    }
                    else
                    {
                        @((MarkupString)Markdown.ToHtml(_incomingMessage ?? string.Empty, _markdownPipeline))
                    }
                </FluentCard>
            }
        }
        <div id="bottom" @ref="_bottomElement"></div>
    </div>
    <div class="chat-input-section">
        @if (_selectedImages.Any() || _selectedFiles.Any())
        {
            <div class="selected-attachments-container">
                @foreach (var image in _selectedImages)
                {
                    <div class="image-preview" title="@image.File.Name">
                        <img src="data:image/@image.File.Extension.TrimStart('.');base64,@image.Base64Preview" alt="@image.File.Name" />
                        <span class="image-dismiss-button" @onclick="@(() => RemoveImage(image))">
                            <FluentIcon Value="@(new Icons.Regular.Size12.Dismiss())" Style="fill: var(--accent-base-color);" />
                        </span>
                    </div>
                }
                @foreach (var file in _selectedFiles)
                {
                    <div class="file-badge" title="@file.Name">
                        <span class="file-name">@file.Name</span>
                        <span class="dismiss-button" @onclick="@(() => RemoveFile(file))">
                            <FluentIcon Value="@(new Icons.Regular.Size12.Dismiss())" Style="fill: var(--accent-base-color)" />
                        </span>
                    </div>
                }
            </div>
        }
        <div class="input-container">
            <div class="attachment-wrapper">
                <InputFile @key="@_inputKey" OnChange="@HandleFileSelected" class="file-input-overlay" multiple/>
                <FluentButton Class="attachment-button"
                              IconStart="@(new Icons.Regular.Size28.Attach().WithColor(_accentColor))"
                              BackgroundColor="rgba(0, 0, 0, 0)"
                              Style="background-color: transparent; width: 100%; height: 100%; pointer-events: none;"
                              Appearance="Appearance.Lightweight"/>
            </div>

            <div class="input-content-wrapper">
                <div @ref="_editorRef"
                     class="chat-input"
                     contenteditable="@(!_isLoading)"
                     data-placeholder="Enter your prompt here..."
                     @onkeydown="HandleKeyDown"
                     @oninput="HandleInput"></div>
            </div>

            <FluentButton class="send-button"
                          IconStart="@(new Icons.Regular.Size28.Send().WithColor(_accentColor))"
                          BackgroundColor="rgba(0, 0, 0, 0)"
                          Style="@(_isLoading ? "display: none;" : "background-color: transparent; margin-bottom: 2px;")"
                          Appearance="Appearance.Lightweight"
                          OnClick="@HandleSend">
            </FluentButton>

            <FluentButton class="stop-button"
                          IconStart="@(new Icons.Filled.Size28.RecordStop().WithColor(_accentColor))"
                          BackgroundColor="rgba(0, 0, 0, 0)"
                          Style="@(_isLoading ? "background-color: transparent; margin-bottom: 2px;" : "display: none;")"
                          Appearance="Appearance.Lightweight"
                          OnClick="@HandleStop">
            </FluentButton>
        </div>
    </div>
</div>

@code {
    private bool _showSettings;
    private bool _hasExistingConfig;
    private bool _isLoading;
    private bool _isThinking;
    private bool _isDragging;
    private bool _preserveScroll;
    private string _accentColor = "#00cca3";
    private string? _errorMessage;
    private string? _incomingMessage;
    private string? _incomingReasoning;
    private IChatMessageBuilder? ctx;
    private CancellationTokenSource? _cancellationTokenSource;
    private Chat Chat { get; set; } = new() { Name = "MaIN Infer", ModelId = Utils.Model ?? "unknown" };
    private List<MessageExt> Messages { get; set; } = new();
    private ElementReference? _bottomElement;
    private ElementReference _editorRef;
    private DotNetObjectReference<Home>? _dotNetRef;
    private List<FileInfo> _selectedFiles = new();
    private List<(FileInfo File, string Base64Preview)> _selectedImages = new();
    private int _inputKey;

    private static readonly HashSet<string> ImageExtensions = [".jpg", ".jpeg", ".png", ".gif", ".webp", ".bmp"];

    private readonly MarkdownPipeline _markdownPipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .UseSoftlineBreakAsHardlineBreak()
        .Build();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = await JS.InvokeAsync<string>("themeManager.load");
            _accentColor = (theme == "dark" || theme == "system-dark") ? "#00ffcc" : "#00cca3";
            await JS.InvokeVoidAsync("scrollManager.attachScrollListener", "messages-container");
            await JS.InvokeVoidAsync("scrollManager.restoreScrollPosition", "messages-container");

            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("editorManager.attachPasteHandler", _editorRef, _dotNetRef);
            await JS.InvokeVoidAsync("editorManager.attachDropZone", "chat-container", _dotNetRef);

            // Settings initialization (requires JS interop, so must be in OnAfterRenderAsync)
            SettingsState.OnSettingsRequested += ShowSettingsFromGear;

            if (Utils.NeedsConfiguration)
            {
                var hasBrowserSettings = await SettingsStorage.HasSettingsAsync();
                if (hasBrowserSettings)
                {
                    await LoadAndApplyBrowserSettings();
                    _hasExistingConfig = true;
                    InitializeChatContext();
                    SettingsState.NotifySettingsApplied();
                }
                else
                {
                    _showSettings = true;
                    _hasExistingConfig = false;
                }
            }
            else
            {
                _hasExistingConfig = true;
            }

            StateHasChanged();
        }
        else if (_preserveScroll)
        {
            _preserveScroll = false;
            await JS.InvokeVoidAsync("scrollManager.restoreScrollPosition", "messages-container");
        }
    }

    protected override Task OnInitializedAsync()
    {
        // Only init chat if CLI args provided (no browser settings needed)
        if (!Utils.NeedsConfiguration && !string.IsNullOrEmpty(Utils.Model))
        {
            InitializeChatContext();
        }

        return base.OnInitializedAsync();
    }

    private void InitializeChatContext()
    {
        try
        {
            var model = ResolveModel();
            if (model != null)
            {
                ModelRegistry.RegisterOrReplace(model);
                var newCtx = AIHub.Chat().WithModel(model.Id);
                // Preserve history on model switch; cast is safe — ChatContext implements both interfaces.
                ctx = Chat.Messages.Count > 0
                    ? (IChatMessageBuilder)newCtx.WithMessages(Chat.Messages)
                    : newCtx;
            }
        }
        catch (MaINCustomException ex)
        {
            _errorMessage = ex.PublicErrorMessage;
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private AIModel? ResolveModel()
    {
        if (string.IsNullOrEmpty(Utils.Model)) return null;

        if (ModelRegistry.TryGetById(Utils.Model, out var registeredModel))
        {
            // When a custom Model Path is set, bake the resolved full path into a generic
            // model so LLMService loads from the right location. This is needed because
            // ctx._chat (which reaches LLMService) is a separate object from Home.razor's Chat,
            // so Chat.Properties never reach the service — the path must be in model.FileName.
            if (Utils.BackendType == BackendType.Self && registeredModel is LocalModel localReg
                && !string.IsNullOrEmpty(Utils.Path))
            {
                var fullPath = Utils.Path.EndsWith(".gguf", StringComparison.OrdinalIgnoreCase)
                    ? Utils.Path
                    : System.IO.Path.Combine(Utils.Path, localReg.FileName);

                return localReg switch
                {
                    IVisionModel vm when localReg is IReasoningModel { ReasonFunction: not null } rm
                        => new GenericLocalVisionReasoningModel(
                            FileName: fullPath, MMProjectPath: vm.MMProjectName ?? "",
                            ReasonFunction: rm.ReasonFunction,
                            MaxContextWindowSize: localReg.MaxContextWindowSize),
                    IVisionModel vm
                        => new GenericLocalVisionModel(
                            FileName: fullPath, MMProjectPath: vm.MMProjectName ?? "",
                            MaxContextWindowSize: localReg.MaxContextWindowSize),
                    IReasoningModel { ReasonFunction: not null } rm
                        => new GenericLocalReasoningModel(
                            FileName: fullPath, ReasonFunction: rm.ReasonFunction,
                            MaxContextWindowSize: localReg.MaxContextWindowSize),
                    _ => new GenericLocalModel(
                            FileName: fullPath,
                            MaxContextWindowSize: localReg.MaxContextWindowSize)
                };
            }
            return registeredModel;
        }

        // Self = local GGUF file; Ollama Local is an HTTP server, not a file path
        if (Utils.BackendType == BackendType.Self)
        {
            string modelFileName;
            if (!string.IsNullOrEmpty(Utils.Path))
            {
                modelFileName = Utils.Path.EndsWith(".gguf", StringComparison.OrdinalIgnoreCase)
                    ? Utils.Path
                    : System.IO.Path.Combine(Utils.Path, $"{Utils.Model.Replace(':', '-')}.gguf");
            }
            else
            {
                modelFileName = $"{Utils.Model.Replace(':', '-')}.gguf";
            }
            return new GenericLocalModel(FileName: modelFileName);
        }

        // Cloud model — pick the right generic type based on capabilities
        bool vision = Utils.Vision;
        bool reasoning = Utils.Reason;
        bool imageGen = Utils.ImageGen;

        if (vision && reasoning)
            return new GenericCloudVisionReasoningModel(Id: Utils.Model, Backend: Utils.BackendType);
        if (vision)
            return new GenericCloudVisionModel(Id: Utils.Model, Backend: Utils.BackendType);
        if (reasoning)
            return new GenericCloudReasoningModel(Id: Utils.Model, Backend: Utils.BackendType);
        if (imageGen)
            return new GenericImageGenerationCloudModel(Id: Utils.Model, Backend: Utils.BackendType);

        return new GenericCloudModel(Id: Utils.Model, Backend: Utils.BackendType);
    }

    private void ReinitializeChat()
    {
        if (string.IsNullOrEmpty(Utils.Model)) return;

        _errorMessage = null;
        Chat.ModelId = Utils.Model;
        Chat.ImageGen = Utils.ImageGen;
        InitializeChatContext();
        StateHasChanged();
    }

    private async Task LoadAndApplyBrowserSettings()
    {
        var settings = await SettingsStorage.LoadSettingsAsync();
        if (settings == null) return;

        var backendType = (BackendType)settings.BackendType;

        string? apiKey = null;
        if (backendType != BackendType.Self)
        {
            var backendKey = backendType == BackendType.Ollama
                ? (settings.IsOllamaCloud ? "OllamaCloud" : "OllamaLocal")
                : backendType.ToString();

            apiKey = await SettingsStorage.GetApiKeyForBackendAsync(backendKey);
        }

        Utils.ApplySettings(
            backendType,
            settings.Model!,
            settings.ModelPath,
            settings.HasVision,
            settings.HasReasoning,
            settings.HasImageGen,
            settings.MmProjName,
            MaINSettings,
            apiKey);
    }

    private void ShowSettingsFromGear()
    {
        _showSettings = true;
        InvokeAsync(StateHasChanged);
    }

    private void HandleSettingsApplied()
    {
        _hasExistingConfig = true;
        _showSettings = false;
        ReinitializeChat();
        SettingsState.NotifySettingsApplied();
    }

    private void HideSettings()
    {
        _showSettings = false;
        StateHasChanged();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e is { Key: "Enter", ShiftKey: false })
        {
            await HandleSend();
        }
    }

    private async Task HandleSend()
    {
        if (_isLoading) return;

        var msg = await JS.InvokeAsync<string>("editorManager.getInnerText", _editorRef);
        if (!string.IsNullOrWhiteSpace(msg) || _selectedFiles.Any() || _selectedImages.Any())
        {
            await JS.InvokeVoidAsync("editorManager.clearContent", _editorRef);
            await SendAsync(msg?.Trim() ?? string.Empty);
        }
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        foreach (var file in e.GetMultipleFiles(10))
        {
            var ms = new MemoryStream();
            try
            {
                await file.OpenReadStream(20 * 1024 * 1024).CopyToAsync(ms);
                ms.Position = 0;

                var extension = Path.GetExtension(file.Name).ToLowerInvariant();
                var fileInfo = new FileInfo
                {
                    Name = file.Name,
                    Extension = extension,
                    StreamContent = ms
                };

                if (ImageExtensions.Contains(extension))
                {
                    if (!Utils.Vision)
                    {
                        _errorMessage = "This model doesn't support image input.";
                        continue;
                    }
                    var base64 = Convert.ToBase64String(ms.ToArray());
                    ms.Position = 0;
                    _selectedImages.Add((fileInfo, base64));
                }
                else
                {
                    _selectedFiles.Add(fileInfo);
                }
            }
            catch (Exception ex)
            {
                await ms.DisposeAsync();
                _errorMessage = $"Failed to read file {file.Name}: {ex.Message}";
            }
        }
        StateHasChanged();
    }

    private void RemoveFile(FileInfo file)
    {
        file.StreamContent?.Dispose();
        _selectedFiles.Remove(file);
    }

    private void RemoveImage((FileInfo File, string Base64Preview) image)
    {
        image.File.StreamContent?.Dispose();
        _selectedImages.Remove(image);
    }

    [JSInvokable]
    public async Task OnFileReceived(string fileName, string extension, string base64Data)
    {
        try
        {
            var bytes = Convert.FromBase64String(base64Data);
            var ms = new MemoryStream(bytes);
            var fileInfo = new FileInfo
            {
                Name = fileName,
                Extension = extension,
                StreamContent = ms
            };

            if (ImageExtensions.Contains(extension.ToLowerInvariant()))
            {
                if (!Utils.Vision)
                {
                    _errorMessage = "This model doesn't support image input.";
                    return;
                }
                _selectedImages.Add((fileInfo, base64Data));
            }
            else
            {
                _selectedFiles.Add(fileInfo);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load file {fileName}: {ex.Message}";
        }

        _isDragging = false;
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnDragEnter()
    {
        _isDragging = true;
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnDragLeave()
    {
        _isDragging = false;
        await InvokeAsync(StateHasChanged);
    }

    private void HandleStop()
    {
        _cancellationTokenSource?.Cancel();
    }

    private async Task SendAsync(string msg)
    {
        if (string.IsNullOrWhiteSpace(msg) && !_selectedFiles.Any() && !_selectedImages.Any())
        {
            return;
        }

        _cancellationTokenSource?.Dispose();
        _cancellationTokenSource = new CancellationTokenSource();
        var cancellationToken = _cancellationTokenSource.Token;

        _isLoading = true;
        StateHasChanged();

        var attachedFiles = new List<FileInfo>(_selectedFiles);
        var attachedImages = new List<(FileInfo File, string Base64Preview)>(_selectedImages);
        try
        {
            _selectedFiles.Clear();
            _selectedImages.Clear();
            _inputKey++;
            StateHasChanged();

            var newMsg = new Message
            {
                Role = "User",
                Content = msg,
                Type = GetMessageType()
            };
            Chat.Messages.Add(newMsg);

            Messages.Add(new MessageExt
            {
                Message = newMsg,
                AttachedFiles = attachedFiles.Select(f => f.Name).ToList(),
                AttachedImages = attachedImages.Select(i => (i.File.Name, i.Base64Preview)).ToList()
            });

            Chat.ModelId = Utils.Model!;
            Chat.ImageGen = Utils.ImageGen;

            // Sync mmproj setting for local unregistered vision models
            Chat.Properties.Remove(ServiceConstants.Properties.MmProjNameProperty);
            if (Utils.BackendType == BackendType.Self && !string.IsNullOrEmpty(Utils.MmProjName))
                Chat.Properties.AddProperty(ServiceConstants.Properties.MmProjNameProperty, Utils.MmProjName);

            bool wasAtBottom = await JS.InvokeAsync<bool>("scrollManager.isAtBottom", "messages-container");

            StateHasChanged();

            if (wasAtBottom)
                await JS.InvokeVoidAsync("scrollManager.scrollToBottomSmooth", "messages-container");

            var request = ctx!.WithMessage(msg);

            // Combine files and images - images go as files, ExtractImageFromFiles will handle them
            var allFiles = new List<FileInfo>(attachedFiles);
            allFiles.AddRange(attachedImages.Select(i => i.File));

            if (allFiles.Count != 0)
            {
                request.WithFiles(allFiles);
            }

            cancellationToken.ThrowIfCancellationRequested();

            var completionTask = request.CompleteAsync(changeOfValue: async message =>
            {
                if (cancellationToken.IsCancellationRequested)
                {
                    return;
                }

                if (message?.Type == TokenType.Reason)
                {
                    _isThinking = true;
                    _incomingReasoning += message.Text;
                }
                else if (message?.Type == TokenType.Message)
                {
                    _isThinking = false;
                    _incomingMessage += message.Text;
                }

                await InvokeAsync(StateHasChanged);
                if (wasAtBottom)
                {
                    await InvokeAsync(async () => await JS.InvokeVoidAsync("scrollManager.scrollToBottomSmooth", "messages-container"));
                }
            }, cancellationToken: cancellationToken);

            await completionTask.WaitAsync(cancellationToken);

            var currentChat = await ctx.GetCurrentChat();
            Chat.Messages.Add(currentChat.Messages.Last());

            await JS.InvokeVoidAsync("scrollManager.saveScrollPosition", "messages-container");
            _preserveScroll = true;
            RebuildMessagesWithFiles();
            _incomingReasoning = null;
            _incomingMessage = null;
        }
        catch (OperationCanceledException)
        {
            bool hasPartialResponse = !string.IsNullOrWhiteSpace(_incomingMessage) || !string.IsNullOrWhiteSpace(_incomingReasoning);

            if (hasPartialResponse)
            {
                var partialMsg = new Message
                {
                    Role = "Assistant",
                    Content = _incomingMessage ?? string.Empty,
                    Type = GetMessageType(),
                    Time = DateTime.Now
                };

                if (!string.IsNullOrWhiteSpace(_incomingReasoning))
                    partialMsg.Tokens.Add(new LLMTokenValue { Text = _incomingReasoning, Type = TokenType.Reason });

                if (!string.IsNullOrWhiteSpace(_incomingMessage))
                    partialMsg.Tokens.Add(new LLMTokenValue { Text = _incomingMessage, Type = TokenType.Message });

                Chat.Messages.Add(partialMsg);
                RebuildMessagesWithFiles();
            }
            else
            {
                if (Chat.Messages.Count > 0 && Chat.Messages.Last().Role == "User")
                    Chat.Messages.RemoveAt(Chat.Messages.Count - 1);

                if (Messages.Count > 0 && Messages.Last().Message.Role == "User")
                    Messages.RemoveAt(Messages.Count - 1);
            }

            _incomingReasoning = null;
            _incomingMessage = null;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _errorMessage = null;
            StateHasChanged();

            _errorMessage = ex is MaINCustomException maInException
                ? maInException.PublicErrorMessage
                : ex.Message;

            StateHasChanged();
        }
        finally
        {
            foreach (var attachment in attachedFiles)
                attachment.StreamContent?.Dispose();
            attachedFiles.Clear();

            foreach (var image in attachedImages)
                image.File.StreamContent?.Dispose();
            attachedImages.Clear();

            _isLoading = false;
            _isThinking = false;
            StateHasChanged();
        }
    }

    private void HandleInput(ChangeEventArgs obj)
    {
        // Handled by JS on send to ensure accuracy
    }

    private string GetMessageContent(Message message)
    {
        var tokensContent = string.Concat(message.Tokens.Where(x => x.Type == TokenType.Message).Select(x => x.Text));
        return !string.IsNullOrEmpty(tokensContent) ? tokensContent : message.Content ?? string.Empty;
    }

    private string GetReasoningContent(Message message)
    {
        return string.Concat(message.Tokens.Where(x => x.Type == TokenType.Reason).Select(x => x.Text));
    }

    private MessageType GetMessageType()
    {
        return Utils.IsLocal
            ? MessageType.LocalLLM
            : MessageType.CloudLLM;
    }

    private async Task ToggleReasoning(MessageExt conversation)
    {
        await JS.InvokeVoidAsync("scrollManager.saveScrollPosition", "messages-container");
        _preserveScroll = true;
        conversation.ShowReason = !conversation.ShowReason;
    }

    private void RebuildMessagesWithFiles()
    {
        var existingFilesMap = Messages
            .Where(m => m.AttachedFiles.Any())
            .ToDictionary(m => m.Message, m => m.AttachedFiles);

        var existingImagesMap = Messages
            .Where(m => m.AttachedImages.Any())
            .ToDictionary(m => m.Message, m => m.AttachedImages);

        var existingReasonMap = Messages
            .ToDictionary(m => m.Message, m => m.ShowReason);

        Messages = Chat.Messages.Select(x => new MessageExt
        {
            Message = x,
            AttachedFiles = existingFilesMap.TryGetValue(x, out var files) ? files : new List<string>(),
            AttachedImages = existingImagesMap.TryGetValue(x, out var images) ? images : new List<(string, string)>(),
            ShowReason = existingReasonMap.TryGetValue(x, out var show) && show,
            HasReasoning = x.Tokens.Any(t => t.Type == TokenType.Reason),
            ComputedContent = GetMessageContent(x),
            ComputedReasoning = GetReasoningContent(x)
        }).ToList();
    }

    private async Task CopyImageToClipboard(string base64)
    {
        try
        {
            await JS.InvokeVoidAsync("editorManager.copyImageToClipboard", base64);
        }
        catch
        {
            // silently ignore — clipboard API may not be available in all browsers
        }
    }

    public void Dispose()
    {
        SettingsState.OnSettingsRequested -= ShowSettingsFromGear;
        _cancellationTokenSource?.Dispose();
        _dotNetRef?.Dispose();
    }
}
