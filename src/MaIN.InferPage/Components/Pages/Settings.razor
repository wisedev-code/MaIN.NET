@using MaIN.Domain.Configuration
@using MaIN.Domain.Configuration.Vertex
@using MaIN.Domain.Models.Abstract
@inject SettingsService SettingsStorage
@inject MaINSettings MaINSettings
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<link rel="stylesheet" href="settings.css">

<div class="settings-overlay">
    <div class="settings-panel">
        <div class="settings-header">
            <h2>Settings</h2>
            @if (ShowCloseButton)
            {
                <FluentButton Appearance="Appearance.Lightweight"
                              Style="--neutral-fill-stealth-rest: transparent; --neutral-fill-stealth-hover: rgba(128,128,128,0.15); --neutral-fill-stealth-active: rgba(128,128,128,0.25);"
                              OnClick="@OnClose"
                              IconStart="@(new Icons.Regular.Size24.Dismiss())">
                </FluentButton>
            }
        </div>

        <div class="settings-body">
            <div class="settings-field">
                <label class="settings-label">Backend</label>
                <FluentSelect TOption="BackendOption"
                              Items="@_backendOptions"
                              OptionValue="@(o => o.Id.ToString())"
                              OptionText="@(o => o.DisplayName)"
                              @bind-SelectedOption="_selectedBackend"
                              @bind-SelectedOption:after="OnBackendChanged"
                              Style="width: 100%;" />
            </div>

            <div class="settings-field">
                <label class="settings-label">Model</label>
                <FluentTextField @bind-Value="_modelName"
                                 @bind-Value:after="OnModelNameChanged"
                                 Placeholder="e.g., gpt-4o, gemma3-4b"
                                 Style="width: 100%;" />
            </div>

            @if (RequiresApiKey)
            {
                <div class="settings-field">
                    <label class="settings-label">API Key</label>
                    <div class="api-key-row">
                        <FluentTextField @bind-Value="_apiKeyInput"
                                         Placeholder="Enter API key"
                                         TextFieldType="@(_showApiKey ? TextFieldType.Text : TextFieldType.Password)"
                                         Style="flex: 1;" />
                        <FluentButton Appearance="Appearance.Lightweight"
                                      Style="--neutral-fill-stealth-rest: transparent; --neutral-fill-stealth-hover: rgba(128,128,128,0.15); --neutral-fill-stealth-active: rgba(128,128,128,0.25);"
                                      OnClick="@ToggleApiKeyVisibility"
                                      IconStart="@(_showApiKey
                                          ? new Icons.Regular.Size20.EyeOff()
                                          : (Icon)new Icons.Regular.Size20.Eye())">
                        </FluentButton>
                    </div>
                    @if (!string.IsNullOrEmpty(_savedKeyPreview))
                    {
                        <span class="api-key-hint">Saved: @_savedKeyPreview</span>
                    }
                </div>
            }

            @if (_selectedBackend?.BackendType == BackendType.Vertex)
            {
                <div class="settings-field">
                    <label class="settings-label">Project ID</label>
                    <FluentTextField @bind-Value="_vertexProjectId"
                                     Placeholder="my-google-cloud-project"
                                     Style="width: 100%;" />
                </div>

                <div class="settings-field">
                    <label class="settings-label">Client Email</label>
                    <FluentTextField @bind-Value="_vertexClientEmail"
                                     Placeholder="name@project.iam.gserviceaccount.com"
                                     Style="width: 100%;" />
                </div>

                <div class="settings-field">
                    <label class="settings-label">Private Key</label>
                    <div class="api-key-row">
                        <FluentTextField @bind-Value="_vertexPrivateKey"
                                         Placeholder="Private key from service account JSON"
                                         TextFieldType="@(_showVertexKey ? TextFieldType.Text : TextFieldType.Password)"
                                         Style="flex: 1;" />
                        <FluentButton Appearance="Appearance.Lightweight"
                                      Style="--neutral-fill-stealth-rest: transparent; --neutral-fill-stealth-hover: rgba(128,128,128,0.15); --neutral-fill-stealth-active: rgba(128,128,128,0.25);"
                                      OnClick="@(() => _showVertexKey = !_showVertexKey)"
                                      IconStart="@(_showVertexKey
                                          ? new Icons.Regular.Size20.EyeOff()
                                          : (Icon)new Icons.Regular.Size20.Eye())">
                        </FluentButton>
                    </div>
                    <span class="api-key-hint">private_key field from the service account JSON file</span>
                </div>

                <div class="settings-field">
                    <label class="settings-label">Location</label>
                    <FluentTextField @bind-Value="_vertexLocation"
                                     Placeholder="us-central1"
                                     Style="width: 100%;" />
                    <span class="api-key-hint">Optional — defaults to us-central1</span>
                </div>
            }

            @if (_selectedBackend?.BackendType == BackendType.Self)
            {
                <div class="settings-field">
                    <label class="settings-label">Model Path</label>
                    <FluentTextField @bind-Value="_modelPath"
                                     Placeholder="Optional: model.gguf, C:\dir\model.gguf, or C:\dir"
                                     Style="width: 100%;" />
                    @if (ResolvedModelPathPreview is { } preview)
                    {
                        <span class="api-key-hint">Will load: @preview</span>
                    }
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(_modelName))
            {
                <div class="settings-field">
                    @if (_isRegisteredModel)
                    {
                        <label class="settings-label">Detected Capabilities</label>
                        <div class="capabilities-row">
                            @if (_detectedVision)
                            {
                                <FluentBadge BackgroundColor="#0ea5e9" Color="#fff">Vision</FluentBadge>
                            }
                            @if (_detectedReasoning)
                            {
                                <FluentBadge BackgroundColor="#ffd800" Color="#000">Reasoning</FluentBadge>
                            }
                            @if (_detectedImageGen)
                            {
                                <FluentBadge BackgroundColor="#7c3aed" Color="#fff">Image Gen</FluentBadge>
                            }
                            @if (!_detectedVision && !_detectedReasoning && !_detectedImageGen)
                            {
                                <span class="no-capabilities">No special capabilities</span>
                            }
                        </div>
                        @if (RegisteredMmProjPathHint is { } mmProjHint)
                        {
                            <span class="api-key-hint">MMProj file: @mmProjHint</span>
                        }
                    }
                    else
                    {
                        <label class="settings-label">Model Capabilities</label>
                        <span class="capabilities-hint">Model not in registry. Select supported capabilities:</span>
                        <div class="capabilities-checkboxes">
                            <FluentCheckbox @bind-Value="_manualVision" Label="Vision" />
                            <FluentCheckbox @bind-Value="_manualReasoning" Label="Reasoning" />
                            <FluentCheckbox @bind-Value="_manualImageGen" Label="Image Generation" />
                        </div>
                    }
                </div>
            }

            @if (_selectedBackend?.BackendType == BackendType.Self && !_isRegisteredModel && _manualVision)
            {
                <div class="settings-field">
                    <label class="settings-label">MMProj File</label>
                    <FluentTextField @bind-Value="_mmProjName"
                                     Placeholder="e.g., mmproj-model-f16.gguf"
                                     Style="width: 100%;" />
                    <span class="api-key-hint">Multimodal projector file (must be in the models folder)</span>
                </div>
            }
        </div>

        <div class="settings-footer">
            <FluentButton Appearance="Appearance.Accent"
                          OnClick="@SaveAndApply"
                          Disabled="@(!CanSave)">
                @(ShowCloseButton ? "Save & Apply" : "Get Started")
            </FluentButton>
        </div>
    </div>
</div>

@code {
    [Parameter] public bool ShowCloseButton { get; set; }
    [Parameter] public EventCallback OnSettingsApplied { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private List<BackendOption> _backendOptions = null!;
    private BackendOption? _selectedBackend;
    private string? _modelName;
    private string? _modelPath;
    private string? _apiKeyInput;
    private string? _savedKeyPreview;
    private bool _showApiKey;

    // Vertex AI auth fields
    private string? _vertexProjectId;
    private string? _vertexClientEmail;
    private string? _vertexPrivateKey;
    private string? _vertexLocation;
    private bool _showVertexKey;

    // "Will load:" path preview shown below the model path field (Self backend only)
    private string? ResolvedModelPathPreview
    {
        get
        {
            if (_selectedBackend?.BackendType != BackendType.Self) return null;
            if (string.IsNullOrWhiteSpace(_modelName)) return null;

            // Mirror Utils.ApplySettings sanitization (strips U+202A and other format chars)
            var rawPath = _modelPath?.Trim() ?? "";
            int i = 0;
            while (i < rawPath.Length && (char.IsControl(rawPath[i]) || char.GetUnicodeCategory(rawPath[i]) == System.Globalization.UnicodeCategory.Format))
            {
                i++;
            }

            var cleanPath = i < rawPath.Length ? rawPath.Substring(i) : "";
            var sanitizedModel = $"{_modelName.Trim().Replace(':', '-')}.gguf";

            string fileName;
            if (!string.IsNullOrEmpty(cleanPath))
            {
                fileName = cleanPath.EndsWith(".gguf", StringComparison.OrdinalIgnoreCase)
                    ? cleanPath
                    : Path.Combine(cleanPath, sanitizedModel);
            }
            else
            {
                fileName = sanitizedModel;
            }

            // Relative path: prepend configured models directory
            if (!Path.IsPathFullyQualified(fileName))
            {
                var modelsDir = MaINSettings.ModelsPath
                    ?? Environment.GetEnvironmentVariable("MaIN_ModelsPath");
                if (!string.IsNullOrEmpty(modelsDir))
                    fileName = Path.Combine(modelsDir, fileName);
            }

            return fileName;
        }
    }

    // Registered model detection
    private bool _isRegisteredModel;
    private bool _detectedVision;
    private bool _detectedReasoning;
    private bool _detectedImageGen;

    // Shows expected MMProj file path for registered local vision models.
    // Derives the directory from ResolvedModelPathPreview so it always stays in sync
    // with the "Will load:" hint (including any custom Model Path the user typed).
    private string? RegisteredMmProjPathHint
    {
        get
        {
            if (_selectedBackend?.BackendType != BackendType.Self || !_isRegisteredModel) return null;
            if (!_detectedVision) return null;
            if (string.IsNullOrWhiteSpace(_modelName)) return null;
            if (!ModelRegistry.TryGetById(_modelName, out var aiModel) || aiModel is not LocalModel localModel) return null;
            if (localModel is not IVisionModel visionModel || visionModel.MMProjectName is not { } mmProjName) return null;

            // Reuse the already-resolved model file path to derive the directory,
            // so changes to the Model Path field are immediately reflected here too.
            var modelFilePath = ResolvedModelPathPreview;
            var dir = modelFilePath != null
                ? (Path.GetDirectoryName(modelFilePath) ?? "")
                : (MaINSettings.ModelsPath ?? Environment.GetEnvironmentVariable("MaIN_ModelsPath") ?? "");

            return string.IsNullOrEmpty(dir) ? mmProjName : Path.Combine(dir, mmProjName);
        }
    }

    // Manual capability selection (unregistered models)
    private bool _manualVision;
    private bool _manualReasoning;
    private bool _manualImageGen;
    private string? _mmProjName;

    private bool RequiresApiKey => _selectedBackend?.RequiresApiKey == true;
    private bool IsVertexBackend => _selectedBackend?.BackendType == BackendType.Vertex;
    private bool HasVertexRequiredFields => !string.IsNullOrWhiteSpace(_vertexProjectId)
        && !string.IsNullOrWhiteSpace(_vertexClientEmail)
        && !string.IsNullOrWhiteSpace(_vertexPrivateKey);
    private bool CanSave => !string.IsNullOrWhiteSpace(_modelName)
                            && _selectedBackend != null
                            && (!RequiresApiKey || !string.IsNullOrEmpty(_apiKeyInput) || !string.IsNullOrEmpty(_savedKeyPreview))
                            && (!IsVertexBackend || HasVertexRequiredFields);

    protected override async Task OnInitializedAsync()
    {
        _backendOptions = new List<BackendOption>
        {
            new(1, "OpenAI", BackendType.OpenAi, true),
            new(2, "Gemini", BackendType.Gemini, true),
            new(3, "DeepSeek", BackendType.DeepSeek, true),
            new(4, "GroqCloud", BackendType.GroqCloud, true),
            new(5, "Anthropic", BackendType.Anthropic, true),
            new(6, "xAI", BackendType.Xai, true),
            new(7, "Ollama (Local)", BackendType.Ollama, false),
            new(8, "Ollama (Cloud)", BackendType.Ollama, true),
            new(9, "Vertex AI", BackendType.Vertex, false)
        }.OrderBy(x => x.DisplayName)
         .Prepend(new BackendOption(0, "Local", BackendType.Self, false))
         .ToList();

        await base.OnInitializedAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadCurrentSettings();
            StateHasChanged();
        }
    }

    private async Task LoadCurrentSettings()
    {
        var settings = await SettingsStorage.LoadSettingsAsync();
        if (settings != null)
        {
            var backendType = (BackendType)settings.BackendType;

            if (backendType == BackendType.Ollama)
            {
                _selectedBackend = settings.IsOllamaCloud
                    ? _backendOptions.First(o => o.Id == 8)
                    : _backendOptions.First(o => o.Id == 7);
            }
            else if (backendType == BackendType.Vertex)
            {
                _selectedBackend = _backendOptions.First(o => o.Id == 9);
            }
            else
            {
                _selectedBackend = _backendOptions.FirstOrDefault(o => o.BackendType == backendType && o.Id < 7);
            }

            _modelName = settings.Model;
            _modelPath = settings.ModelPath;
            _manualVision = settings.HasVision;
            _manualReasoning = settings.HasReasoning;
            _manualImageGen = settings.HasImageGen;
            _mmProjName = settings.MmProjName;

            if (backendType == BackendType.Vertex)
            {
                var vertexAuth = await SettingsStorage.GetVertexAuthAsync();
                if (vertexAuth != null)
                {
                    _vertexProjectId = vertexAuth.ProjectId;
                    _vertexClientEmail = vertexAuth.ClientEmail;
                    _vertexPrivateKey = vertexAuth.PrivateKey;
                }
                _vertexLocation = settings.VertexLocation;
            }

            OnModelNameChanged();
        }
        else if (!Utils.NeedsConfiguration)
        {
            // Load from current Utils state (CLI-configured)
            _selectedBackend = Utils.BackendType == BackendType.Ollama
                ? (Utils.HasApiKey
                    ? _backendOptions.First(o => o.Id == 8)
                    : _backendOptions.First(o => o.Id == 7))
                : Utils.BackendType == BackendType.Vertex
                    ? _backendOptions.First(o => o.Id == 9)
                    : _backendOptions.FirstOrDefault(o => o.BackendType == Utils.BackendType && o.Id < 7);

            _modelName = Utils.Model;
            _modelPath = Utils.Path;

            OnModelNameChanged();
        }

        if (_selectedBackend != null)
            await LoadApiKeyPreview();
    }

    private async Task OnBackendChanged()
    {
        if (_selectedBackend == null) return;

        var backendKey = GetBackendStorageKey();
        var profile = await SettingsStorage.GetProfileForBackendAsync(backendKey);
        if (profile != null)
        {
            _modelName = profile.Model;
            OnModelNameChanged();                    // sets _isRegisteredModel + auto-detects caps
            if (!_isRegisteredModel)                // only restore manual caps for unregistered models
            {
                _manualVision    = profile.Vision;
                _manualReasoning = profile.Reasoning;
                _manualImageGen  = profile.ImageGen;
                _mmProjName      = profile.MmProjName;
            }
        }
        else
        {
            // Fallback: old model-history entry (no capability info)
            var lastModel = await SettingsStorage.GetLastModelForBackendAsync(backendKey);
            if (!string.IsNullOrEmpty(lastModel))
            {
                _modelName = lastModel;
                OnModelNameChanged();
            }
        }

        if (IsVertexBackend)
        {
            var vertexAuth = await SettingsStorage.GetVertexAuthAsync();
            if (vertexAuth != null)
            {
                _vertexProjectId = vertexAuth.ProjectId;
                _vertexClientEmail = vertexAuth.ClientEmail;
                _vertexPrivateKey = vertexAuth.PrivateKey;
            }
            else
            {
                _vertexProjectId = null;
                _vertexClientEmail = null;
                _vertexPrivateKey = null;
            }

            var settings = await SettingsStorage.LoadSettingsAsync();
            _vertexLocation = settings?.VertexLocation;
        }

        await LoadApiKeyPreview();
        _apiKeyInput = null;
    }

    private void OnModelNameChanged()
    {
        if (string.IsNullOrWhiteSpace(_modelName))
        {
            _isRegisteredModel = false;
            return;
        }

        _isRegisteredModel = ModelRegistry.TryGetById(_modelName, out var model);
        if (_isRegisteredModel && model != null)
        {
            _detectedVision = model is IVisionModel;
            _detectedReasoning = model is IReasoningModel;
            _detectedImageGen = model is IImageGenerationModel;
        }
        else
        {
            _detectedVision = false;
            _detectedReasoning = false;
            _detectedImageGen = false;

            // Pre-check known models from fallback lists
            if (Utils.IsKnownVisionModel(_modelName)) _manualVision = true;
            if (Utils.IsKnownImageGenModel(_modelName)) _manualImageGen = true;
        }
    }

    private async Task LoadApiKeyPreview()
    {
        if (_selectedBackend == null || !_selectedBackend.RequiresApiKey)
        {
            _savedKeyPreview = null;
            return;
        }

        var backendKey = GetBackendStorageKey();
        var savedKey = await SettingsStorage.GetApiKeyForBackendAsync(backendKey);

        _savedKeyPreview = string.IsNullOrEmpty(savedKey)
            ? null
            : MaskApiKey(savedKey);
    }

    private void ToggleApiKeyVisibility()
    {
        _showApiKey = !_showApiKey;
    }

    private async Task SaveAndApply()
    {
        if (_selectedBackend == null || string.IsNullOrWhiteSpace(_modelName)) return;

        var backendKey = GetBackendStorageKey();
        var isOllamaCloud = _selectedBackend.Id == 8;

        bool hasVision, hasReasoning, hasImageGen;
        if (_isRegisteredModel)
        {
            hasVision = _detectedVision;
            hasReasoning = _detectedReasoning;
            hasImageGen = _detectedImageGen;
        }
        else
        {
            hasVision = _manualVision;
            hasReasoning = _manualReasoning;
            hasImageGen = _manualImageGen;
        }

        var settings = new InferPageSettings
        {
            BackendType = (int)_selectedBackend.BackendType,
            IsOllamaCloud = isOllamaCloud,
            Model = _modelName,
            HasVision = hasVision,
            HasReasoning = hasReasoning,
            HasImageGen = hasImageGen,
            ModelPath = _modelPath,
            MmProjName = _mmProjName,
            VertexLocation = IsVertexBackend ? _vertexLocation : null
        };
        await SettingsStorage.SaveSettingsAsync(settings);

        await SettingsStorage.SaveProfileForBackendAsync(
            backendKey, _modelName, hasVision, hasReasoning, hasImageGen, _mmProjName);

        // Resolve API key: use new input, or fall back to saved key
        string? apiKey = null;
        if (RequiresApiKey)
        {
            if (!string.IsNullOrWhiteSpace(_apiKeyInput))
            {
                apiKey = _apiKeyInput;
                await SettingsStorage.SaveApiKeyAsync(backendKey, apiKey);
            }
            else
            {
                apiKey = await SettingsStorage.GetApiKeyForBackendAsync(backendKey);
            }
        }

        // Vertex AI: persist auth and build config
        GoogleServiceAccountConfig? vertexAuth = null;
        if (IsVertexBackend && HasVertexRequiredFields)
        {
            await SettingsStorage.SaveVertexAuthAsync(_vertexProjectId!, _vertexClientEmail!, _vertexPrivateKey!);
            vertexAuth = new GoogleServiceAccountConfig
            {
                ProjectId = _vertexProjectId!,
                ClientEmail = _vertexClientEmail!,
                PrivateKey = _vertexPrivateKey!
            };
        }

        Utils.ApplySettings(
            _selectedBackend.BackendType,
            _modelName,
            _modelPath,
            hasVision,
            hasReasoning,
            hasImageGen,
            _mmProjName,
            MaINSettings,
            apiKey,
            vertexAuth);

        await OnSettingsApplied.InvokeAsync();
    }

    private string GetBackendStorageKey()
    {
        if (_selectedBackend == null) return "Self";
        if (_selectedBackend.Id == 7) return "OllamaLocal";
        if (_selectedBackend.Id == 8) return "OllamaCloud";
        if (_selectedBackend.Id == 9) return "Vertex";
        return _selectedBackend.BackendType.ToString();
    }

    private static string MaskApiKey(string key)
    {
        if (key.Length <= 12) return key;
        return key[..6] + "..." + key[^6..];
    }

    public record BackendOption(int Id, string DisplayName, BackendType BackendType, bool RequiresApiKey);
}